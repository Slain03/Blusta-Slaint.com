const seed = (s)=>{ let x=s; return ()=>{ x=Math.sin(x)*10000; return x-Math.floor(x); }; };

const makePairs = () => {
  const names=[
    ["SLN","WETH","eth","Uniswap V3","0x1234","#","#"],
  ];
  const r=seed(42);
  return names.map(([base,quote,chain,dex,addr,supply,fdv],i)=>{
    const price = r()*0.1+0.0001;
    const c5m=(r()-.4)*8, c1h=(r()-.45)*15, c6h=(r()-.4)*30, c24h=(r()-.38)*50;
    const vol24=r()*50e6+1e6, liq=r()*5e6+100e3, txns=Math.floor(r()*2000+100);
    const buys=Math.floor(txns*(r()*.4+.3)), sells=txns-buys;
    return {
      id:i, base, quote, chain, dex, addr,
      price: price.toFixed(price<0.001?8:price<0.01?6:price<1?4:2),
      c5m:c5m.toFixed(2), c1h:c1h.toFixed(2), c6h:c6h.toFixed(2), c24h:c24h.toFixed(2),
      vol24: fmtNum(vol24), liq: fmtNum(liq), fdv, supply,
      txns, buys, sells,
      age: ["2m","14m","1h","3h","7h","12h","1d","3d","7d","14d","21d","30d","45d","60d","3m","4m","5m","6m","8m","1y"][i%20],
      hot: r()>.7, boosted: r()>.8, audit: r()>.6,
    };
  });
};

function fmtNum(n){
  if(n>=1e9) return "$"+(n/1e9).toFixed(2)+"B";
  if(n>=1e6) return "$"+(n/1e6).toFixed(2)+"M";
  if(n>=1e3) return "$"+(n/1e3).toFixed(1)+"K";
  return "$"+n.toFixed(2);
}

const PAIRS = makePairs();
