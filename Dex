        <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:10}}>
          <AdminKPI label="Critical (24h)" value="12" color="#ef4444"/>
          <AdminKPI label="High (24h)" value="44" color="#f59e0b"/>
          <AdminKPI label="Resolved" value="98%" color="#22c55e"/>
        </div>
        <div style={{background:"#0d0d0f",border:"1px solid #1a1a22",borderRadius:8,overflow:"hidden"}}>
          {[
            {type:"🔴",msg:"Honeypot: 0x9a2b…f3c1",t:"2m ago",sev:"Critical",c:"#ef4444"},
            {type:"🟡",msg:"Volume spike: BONK +1200% 5m",t:"8m ago",sev:"High",c:"#f59e0b"},
            {type:"🔴",msg:"Rug pull suspected: 0xaabb…",t:"14m ago",sev:"Critical",c:"#ef4444"},
            {type:"🟡",msg:"Unusual txn pattern: 0x11cc…",t:"22m ago",sev:"Medium",c:"#eab308"},
            {type:"🟢",msg:"Indexer recovered from lag",t:"31m ago",sev:"Info",c:"#22c55e"},
          ].map((a,i)=>(
            <div key={i} style={{display:"flex",alignItems:"center",gap:12,padding:"10px 16px",borderBottom:"1px solid #111118"}}>
              <span style={{fontSize:16}}>{a.type}</span>
              <span style={{flex:1,fontSize:12,color:"#d8d8e8"}}>{a.msg}</span>
              <Tag color={a.sev==="Critical"?"#3e0000":a.sev==="High"?"#3e2000":"#1a1a22"} text={a.c}>{a.sev}</Tag>
              <span style={{color:"#444455",fontSize:10}}>{a.t}</span>
              <button style={{background:"#141418",border:"1px solid #2a2a35",borderRadius:4,color:"#888899",padding:"3px 8px",cursor:"pointer",fontSize:10}}>Resolve</button>
            </div>
          ))}
        </div>
      </div>
    ),
  };
  return(
    <div style={{display:"flex",height:"100vh",background:"#0a0a0e"}}>
      <AdminNav tab={tab} setTab={setTab}/>
      <div style={{flex:1,display:"flex",flexDirection:"column",overflow:"hidden"}}>
        <div style={{height:52,background:"#0a0a0e",borderBottom:"1px solid #1a1a22",
          display:"flex",alignItems:"center",padding:"0 20px",gap:12,flexShrink:0}}>
          <span style={{fontWeight:600,fontSize:14,color:"#c8c8d8"}}>{titles[tab]||tab}</span>
          <div style={{marginLeft:"auto",display:"flex",gap:8,alignItems:"center"}}>
            <div style={{fontSize:10,color:"#22c55e",display:"flex",alignItems:"center",gap:5,
              background:"#0d2d1a",border:"1px solid #22c55e33",borderRadius:5,padding:"3px 8px"}}>
              <span style={{width:6,height:6,borderRadius:"50%",background:"#22c55e",
                animation:"pulse 2s infinite",display:"inline-block"}}/>
              Live · Block #21,441,332
            </div>
            <button onClick={onExit} style={{background:"#141418",border:"1px solid #2a2a35",
              borderRadius:5,color:"#888899",padding:"5px 12px",cursor:"pointer",fontSize:11}}>← Exit Admin</button>
          </div>
        </div>
        <div style={{flex:1,overflowY:"auto",padding:16}} className="fade" key={tab}>
          {content[tab]||<div style={{color:"#555566",padding:40,textAlign:"center"}}>Coming soon</div>}
        </div>
      </div>
    </div>
  );
};

/* ═══════════════════════════════════════════
   ROOT APP
═══════════════════════════════════════════ */
export default function App(){
  const [adminMode,setAdminMode]=useState(true);
  const [page,setPage]=useState("screener");
  const [selectedPair,setSelectedPair]=useState(true);

  const handleSelectPair=(p)=>{ setSelectedPair(p); setPage("pair"); };
  const handleBack=()=>{ setSelectedPair( ); setPage("screener"); };

  if(adminMode) return(
    <><style>{G}</style><AdminPanel onExit={()=>setAdminMode(true)}/></>
  );

  return(
    <>
      <style>{G}</style>
      <div style={{display:"flex",flexDirection:"column",height:"100vh",overflow:"hidden"}}>
        <TopNav page={page} setPage={p=>{setPage(p);setSelectedPair( );}} setAdminMode={setAdminMode}/>
        <div style={{flex:1,overflow:"hidden",display:"flex",flexDirection:"column"}} className="fade" key={page+selectedPair?.id}>
          {page==="screener"&&<ScreenerPage onSelectPair={handleSelectPair}/>}
          {page==="trending"&&<TrendingPage onSelectPair={handleSelectPair}/>}
          {page==="new"&&<NewPairsPage onSelectPair={handleSelectPair}/>}
          {page==="gainers"&&<GainersPage onSelectPair={handleSelectPair}/>}
          {page==="multicharts"&&<MultichartsPage/>}
          {page==="pair"&&selectedPair&&<PairDetail pair={selectedPair} onBack={handleBack}/>}
        </div>
      </div>
    </>
  );
}