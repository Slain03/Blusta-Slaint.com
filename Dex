/* ─────────────────────────────────────────────
   CANDLE CHART
───────────────────────────────────────────── */
const CandleChartFull = ({pair})=>{
  const r=seed(pair.id*17+3);
  const H=220,W=700,N=80;
  const up=parseFloat(pair.c24h)>=0;
  const candles=Array.from({length:N},(_,i)=>{
    const trend=up?1:-1;
    const base=parseFloat(pair.price)*(1+trend*(N-i)*0.0008);
    const o=base*(1+(r()-.5)*.012);
    const c=base*(1+(r()-.5)*.012);
    const h=Math.max(o,c)*(1+r()*.006);
    const l=Math.min(o,c)*(1-r()*.006);
    return {o,c,h,l};
  });
  const all=candles.flatMap(c=>[c.h,c.l]);
  const mn=Math.min(...all),mx=Math.max(...all),rng=mx-mn||1;
  const toY=p=>H-((p-mn)/rng)*(H-8)-4;
  const cw=6,gap=2.5;
  const volH=40;
  return(
    <div style={{background:"#0d0d0f",borderBottom:"1px solid #1a1a22",padding:"12px 16px"}}>
      <div style={{display:"flex",gap:6,marginBottom:8}}>
        {["1m","5m","15m","1h","4h","1D","1W"].map((t,i)=>(
          <Btn key={t} active={i===3} style={{padding:"2px 8px",fontSize:10}}>{t}</Btn>
        ))}
        <div style={{marginLeft:"auto",display:"flex",gap:6}}>
          {["Candles","Line","Area"].map((t,i)=>(
            <Btn key={t} active={i===0} style={{padding:"2px 8px",fontSize:10}}>{t}</Btn>
          ))}
        </div>
      </div>
      <div style={{overflowX:"auto"}}>
        <svg width={W} height={H+volH} style={{display:"block"}}>
          {[0,.25,.5,.75,1].map(f=>{
            const price=(mn+f*rng).toFixed(parseFloat(pair.price)<0.01?8:4);
            const y=toY(mn+f*rng);
            return(
              <g key={f}>
                <line x1={0} y1={y} x2={W} y2={y} stroke="#1a1a22" strokeWidth={.5}/>
                <text x={W-4} y={y-3} fill="#444455" fontSize={8} textAnchor="end">{price}</text>
              </g>
            );
          })}
          {candles.map((c,i)=>{
            const x=i*(cw+gap)+20;
            const bull=c.c>=c.o;
            const col=bull?"#22c55e":"#ef4444";
            const bodyY=toY(Math.max(c.o,c.c));
            const bodyH=Math.max(1,Math.abs(toY(c.o)-toY(c.c)));
            const v=r()*volH*.9+2;
            return(
              <g key={i}>
                <line x1={x+cw/2} y1={toY(c.h)} x2={x+cw/2} y2={toY(c.l)} stroke={col} strokeWidth={.8}/>
                <rect x={x} y={bodyY} width={cw} height={bodyH}
                  fill={bull?col:col} stroke={col} strokeWidth={.6} rx={.5}/>
                {bull&&<rect x={x} y={bodyY} width={cw} height={bodyH} fill={col} fillOpacity={.3} rx={.5}/>}
                <rect x={x} y={H+volH-v} width={cw} height={v} fill={col+"66"} rx={1}/>
              </g>
            );
          })}
          <line x1={0} y1={toY(parseFloat(pair.price))} x2={W} y2={toY(parseFloat(pair.price))}
            stroke="#22c55e" strokeWidth={.8} strokeDasharray="4 3"/>
        </svg>
      </div>
    </div>
  );
};

