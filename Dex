const Spark = ({up=true,w=60,h=22})=>{
  const r=seed(Math.random()*999);
  const pts=Array.from({length:16},(_,i)=>{
    const base=up?8+i*0.8:18-i*0.8;
    return Math.max(2,Math.min(h-2,base+(r()-.5)*6));
  });
  const path=pts.map((y,x)=>`${x===0?"M":"L"}${(x/15)*w},${h-y}`).join(" ");
  const fill=pts.map((y,x)=>`${(x/15)*w},${h-y}`).join(" ")+` ${w},${h} 0,${h}`;
  const col=up?"#22c55e":"#ef4444";
  return(
    <svg width={w} height={h} style={{display:"block"}}>
      <defs>
        <linearGradient id={`sp${up?1:0}`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor={col} stopOpacity=".2"/>
          <stop offset="100%" stopColor={col} stopOpacity="0"/>
        </linearGradient>
      </defs>
      <polygon points={fill} fill={`url(#sp${up?1:0})`}/>
      <path d={path} fill="none" stroke={col} strokeWidth="1.2"/>
    </svg>
  );
};

